# Local runtime configuration for the Spring Boot app.
# Copy to .env only for local runs. Do not commit real secrets.

DATABASE_URL=jdbc:postgresql://localhost:5432/warehouse_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres_password

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=user
RABBITMQ_PASSWORD=password
RABBITMQ_VHOST=/
RABBITMQ_SSL_ENABLED=false

# GitHub Actions deploy_image.yml notes:
# - AWS_REGION and ECR_REPOSITORY are already declared in .github/workflows/deploy_image.yml.
# - AWS_ROLE_ARN must be configured as a GitHub repository secret, not in this file.
